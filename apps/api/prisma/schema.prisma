generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         Int         @id @default(autoincrement())
  supabaseId String?     @unique
  email      String      @unique
  name       String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  studyPlans StudyPlan[]
  editais Edital[]
}

model StudyPlan {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  is_active   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId Int
  user   User @relation(fields: [userId], references: [id])
  disciplines Discipline[]

}

model Discipline {
  id          Int      @id @default(autoincrement())
  name        String
  color       String
  weight      Float    @default(1.0)
  studyPlanId Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  topics      Topic[]
  priority    String?   @default("MEDIUM") // HIGH, MEDIUM, LOW
  proficiency String?   @default("BEGINNER") // BEGINNER, INTERMEDIATE, ADVANCED
  active      Boolean   @default(true)
  studyLogs   StudyLog[]
  errorLogs   ErrorLog[]
  studyPlan StudyPlan @relation(fields: [studyPlanId], references: [id], onDelete: Cascade)
}

model Topic {
  id           Int      @id @default(autoincrement())
  name         String
  description  String?
  isCompleted  Boolean  @default(false)
  disciplineId Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  discipline Discipline @relation(fields: [disciplineId], references: [id], onDelete: Cascade)
}

enum EditalStatus {
  open
  closed
  draft
}

model Edital {
  id          Int         @id @default(autoincrement())
  title       String
  org         String?
  area        String?
  status      EditalStatus @default(draft)
  publishDate DateTime?
  deadline    DateTime?
  filePath    String
  fileName    String
  fileSize    Int
  mimeType    String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
}


// 2. Crie o modelo StudyLog (transcrito do original)
model StudyLog {
  id              Int      @id @default(autoincrement())
  disciplineId    Int
  discipline      Discipline @relation(fields: [disciplineId], references: [id], onDelete: Cascade)
  topicName       String
  date            DateTime
  durationMinutes Int
  questionsCount  Int      @default(0)
  correctCount    Int      @default(0)
  notes           String?
  
  createdAt       DateTime @default(now())
}
// 3. Crie o modelo ErrorLog (transcrito do original)
model ErrorLog {
  id             Int      @id @default(autoincrement())
  disciplineId   Int
  discipline     Discipline @relation(fields: [disciplineId], references: [id], onDelete: Cascade)
  topicName      String
  reason         String   // KNOWLEDGE_GAP, ATTENTION, INTERPRETATION, etc
  description    String
  correction     String
  
  createdAt      DateTime @default(now())
}